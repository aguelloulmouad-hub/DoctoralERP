<odoo>
<template id="attestation_jury_template">
    <t t-call="stc.report_custom_layout">
      <style type="text/css">
        .page {
          page-break-after: always;
        }
      </style>
      <t t-foreach="docs" t-as="o">
        <t t-foreach="o.jurys_ids" t-as="j">
          <div class="page" style="font-family: Times New Roman, serif; font-size: 14pt;">
            <div style="text-align:center; margin-bottom:10px;">
              <span style="font-size:22px; font-family: cursive;">Attestation</span>
              <div>-------</div>
            </div>
            <p style="text-align:justify;">
              <strong>Je soussigné, Doyen de la Faculté des Sciences et Techniques Béni Mellal</strong>,
              atteste par la présente que le Professeur
              <span style="text-decoration:underline;"><t t-esc="j.nom"/></span>
              a été <strong><t t-esc="j.role_par_ced.role"/></strong> du Jury de la thèse de Doctorat de
              <strong>Mr/Madame <t t-esc="o.doctorant_id.name"/></strong>
              qui a été soutenue le
              <strong>
                <t t-esc="o.date_soutenance"/>
              </strong>.
            </p>
            <p>
              <strong>Intitulé :</strong>
              <span style="text-decoration:underline; font-style:italic;">
                <t t-esc="o.name"/>
              </span>
            </p>
            <p style="text-align:justify;">
              <strong>Cette attestation est délivrée à l'intéressé(e) pour valoir et servir ce que de droit.</strong>
            </p>
            <div style="margin-top:40px; text-align:right;">
              Béni Mellal le, <t t-esc="o.date_soutenance"/>.<br/><br/>
              <strong>Le Doyen</strong>
            </div>
          </div>
        </t>
      </t>
    </t>
</template>
</odoo>
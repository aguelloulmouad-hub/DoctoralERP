<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stc_specialite_tree" model="ir.ui.view">
        <field name="name">stc.specialite.tree</field>
        <field name="model">stc.specialite</field>
        <field name="arch" type="xml">
            <tree string="Spécialités">
                <field name="name"/>
            </tree>
        </field>
    </record>
    <record id="view_stc_specialite_form" model="ir.ui.view">
        <field name="name">stc.specialite.form</field>
        <field name="model">stc.specialite</field>
        <field name="arch" type="xml">
            <form string="Spécialité">
                <group>
                    <field name="name"/>
                </group>
            </form>
        </field>
    </record>
</odoo> 
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stc_rapporteur_proposition_tree" model="ir.ui.view">
        <field name="name">stc.rapporteur.proposition.tree</field>
        <field name="model">stc.rapporteur.proposition</field>
        <field name="arch" type="xml">
            <tree string="Propositions de Rapporteurs">
                <field name="rapporteur_nom"/>
                <field name="grade"/>
                <field name="institution"/>
                <field name="email"/>
                <field name="tel"/>
                <field name="filename"/>
                <field name="fichier" widget="binary" readonly="1" filename="filename"/>
                <field name="numero_bo"/>
                <field name="date"/>
                <field name="CV_filename"/>
                <field name="CV_fichier" widget="binary" readonly="1" filename="CV_filename"/>
                <button name="action_upload_fichier" string="Upload" type="object" icon="fa-upload"/>
                <button name="action_upload_cv" string="Upload CV" type="object" icon="fa-upload"/>
                <field name="avis_favorable" widget="boolean_toggle"/>
                <field name="choisie" widget="boolean_toggle"/>
                <button name="action_toggle_avis" string="Basculer Avis" type="object" icon="fa-exchange"/>
                <field name="soutenance_id"/>
            </tree>
        </field>
    </record>
    <record id="view_stc_rapporteur_proposition_form" model="ir.ui.view">
        <field name="name">stc.rapporteur.proposition.form</field>
        <field name="model">stc.rapporteur.proposition</field>
        <field name="arch" type="xml">
            <form string="Proposition de Rapporteur">
                <group>
                    <field name="soutenance_id"/>
                    <field name="rapporteur_nom"/>
                    <field name="grade"/>
                    <field name="institution"/>
                    <field name="email"/>
                    <field name="numero_bo"/>
                    <field name="date"/>
                    <field name="avis_favorable" widget="boolean_toggle"/>
                    <field name="fichier" widget="binary" filename="filename"/>
                    <field name="CV_filename"/>
                    <field name="CV_fichier" widget="binary" filename="CV_filename"/>
                    <button name="action_upload_cv" string="Upload CV" type="object" icon="fa-upload"/>
                </group>
            </form>
        </field>
    </record>
    <record id="view_stc_rapporteur_proposition_search" model="ir.ui.view">
        <field name="name">stc.rapporteur.proposition.search</field>
        <field name="model">stc.rapporteur.proposition</field>
        <field name="arch" type="xml">
            <search string="Recherche Proposition Rapporteur">
                <field name="rapporteur_nom"/>
                <field name="soutenance_id"/>
            </search>
        </field>
    </record>
</odoo> 
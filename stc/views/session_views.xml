<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stc_session_tree" model="ir.ui.view">
        <field name="name">stc.session.tree</field>
        <field name="model">stc.session</field>
        <field name="arch" type="xml">
            <tree string="Sessions">
                <field name="name"/>
                <field name="date"/>
                <field name="statut"/>
            </tree>
        </field>
    </record>

    <record id="view_stc_session_form" model="ir.ui.view">
        <field name="name">stc.session.form</field>
        <field name="model">stc.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="statut"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stc_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">stc.session</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo> 
<odoo>
<record id="view_modifier_demande_wizard_form" model="ir.ui.view">
    <field name="name">modifier.demande.wizard.form</field>
    <field name="model">modifier.demande.wizard</field>
    <field name="arch" type="xml">
        <form string="Modifier la demande de soutenance">
            <group>
                <field name="name"/>
                <field name="doctorant_id"/>
            </group>
            <group>
                <field name="documents_ids">
                    <tree editable="bottom">
                        <field name="typedoc_id"/>
                        <field name="filename"/>
                        <field name="fichier"/>
                    </tree>
                </field>
            </group>
            <footer>
                <button string="Appliquer" type="object" name="action_apply" class="btn-primary"/>
                <button string="Annuler" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

<record id="view_import_rapporteurs_wizard_form" model="ir.ui.view">
    <field name="name">import.rapporteurs.wizard.form</field>
    <field name="model">import.rapporteurs.wizard</field>
    <field name="arch" type="xml">
        <form string="Importer des rapporteurs depuis Excel">
            <field name="state" invisible="1"/>
            <group states="import">
                <field name="file"/>
                <div class="alert alert-info" style="margin-top: 10px;">
                    <b>Format attendu du fichier Excel :</b><br/>
                    <img src="/stc/static/src/img/rapporteurs.png" style="max-width:100%; border:1px solid #ccc; margin:10px 0;"/>
                    <i>La première ligne doit contenir les en-têtes.</i>
                </div>
            </group>
            <group states="preview">
                <field name="rapporteurs_lines">
                    <tree editable="bottom">
                        <field name="rapporteur_nom"/>
                        <field name="grade"/>
                        <field name="institution"/>
                        <field name="email"/>
                        <field name="tel"/>
                        <field name="numero_bo"/>
                        <field name="date"/>
                    </tree>
                </field>
            </group>
            <footer>
                <button string="Importer" type="object" name="action_import" class="btn-primary" states="import"/>
                <button string="Confirmer l'import" type="object" name="action_confirm_import" class="btn-primary" states="preview"/>
                <button string="Retour" type="object" name="action_back_to_import" class="btn-secondary" states="preview"/>
                <button string="Annuler" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

<record id="view_rapporteur_upload_fichier_wizard_form" model="ir.ui.view">
    <field name="name">rapporteur.upload.fichier.wizard.form</field>

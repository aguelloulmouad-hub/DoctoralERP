<record id="view_import_jury_wizard_form" model="ir.ui.view">
    <field name="name">import.jury.wizard.form</field>
    <field name="model">import.jury.wizard</field>
    <field name="arch" type="xml">
        <form string="Importer le jury depuis Excel">
            <field name="state" invisible="1"/>
            <group states="import">
                <field name="file"/>
                <div class="alert alert-info" style="margin-top: 10px;">
                    <b>Format attendu du fichier Excel :</b><br/>
                    <img src="/stc/static/src/img/jury_plan.png" style="max-width:100%; border:1px solid #ccc; margin:10px 0;"/>
                    <i>La première ligne doit contenir les en-têtes.</i>
                </div>
            </group>
            <group states="preview">
                <group string="Planification">
                    <field name="date_soutenance"/>
                    <field name="lieu"/>
                </group>
            </group>
            <group string="Membres du jury" states="preview">
                <field name="jury_lines">
                    <tree editable="bottom">
                        <field name="nom"/>
                        <field name="nom_ar"/>
                        <field name="grade"/>
                        <field name="institution"/>
                        <field name="email"/>
                        <field name="tel"/>
                        <field name="role"/>
                        <field name="role_par_ced"/>
                        <field name="numero_bo"/>
                        <field name="date"/>
                    </tree>
                </field>
            </group>
            <footer>
                <button string="Importer" type="object" name="action_import" class="btn-primary" states="import"/>
                <button string="Confirmer l'import" type="object" name="action_confirm_import" class="btn-primary" states="preview"/>
                <button string="Retour" type="object" name="action_back_to_import" class="btn-secondary" states="preview"/>
                <button string="Annuler" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>


<record id="view_avis_commission_wizard_form" model="ir.ui.view">
    <field name="name">avis.commission.wizard.form</field>
    <field name="model">avis.commission.wizard</field>
    <field name="arch" type="xml">
        <form string="Saisir l'avis de la commission">
            <group>
                <field name="action_type" widget="radio"/>
                <field name="avis_commission" placeholder="Saisir l'avis de la commission..." required="1"/>
                <field name="motif_rejet" attrs="{'required': [('action_type', '=', 'refuser')], 'invisible': [('action_type', '!=', 'refuser')]}">
                </field>
            </group>
            <group attrs="{'invisible': [('action_type', '=', 'refuser')]}">
                <field name="nb_articles" attrs="{'required': [('action_type', 'in', ['valider','accepter_conditionnel'])]}"/>
                <field name="nb_chapter_books" attrs="{'required': [('action_type', 'in', ['valider','accepter_conditionnel'])]}"/>
                <field name="nb_communications" attrs="{'required': [('action_type', 'in', ['valider','accepter_conditionnel'])]}"/>
                <field name="traite_par_id" attrs="{'required': [('action_type', 'in', ['valider','accepter_conditionnel'])]}"/>
            </group>
            <footer>
                <button string="Valider" type="object" name="action_apply" class="btn-primary"/>
                <button string="Annuler" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>


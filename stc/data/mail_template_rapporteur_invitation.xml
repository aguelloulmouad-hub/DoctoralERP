<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_rapporteur_invitation" model="mail.template">
            <field name="name">Invitation à participer en tant que rapporteur</field>
            <field name="model_id" ref="stc.model_stc_rapporteur_proposition"/>
            <field name="subject">Invitation à participer en tant que rapporteur: ${object.soutenance_id.name}</field>
            <field name="email_from">${(user.email or 'noreply@example.com')|safe}</field>
            <field name="email_to">${object.email | safe}</field>
            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; font-size: 14px;">
                    <p>Bonjour ${object.rapporteur_nom},</p>
                    <p>
                        Vous trouverez en pièce jointe votre invitation en tant que rapporteur pour la soutenance intitulée <strong>${object.soutenance_id.name}</strong>.
                    </p>
                    <p>Cordialement,</p>
                    <br/>
                    <p><em>${user.name}</em></p>
                    <br/>
                    <div style="margin-top:20px; font-size:13px;">
                        Faculté des Sciences et Techniques<br/>
                        Université Sultan Moulay Slimane<br/>
                        Beni-Mellal Maroc<br/>
                        Tél :  +212 5 23 48 51 12/22/82<br/>
                        Fax : +212 5 23 48 52 01
                    </div>
                </div>
            ]]></field>
        </record>
    </data>
</odoo> 